# Kopiér til .env og udfyld. Bruges kun til lokal test.
# Opret en bot via @BotFather i Telegram for at få token.
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenFromBotFather
# Din chat-id (se README for hvordan du finder den).
TELEGRAM_CHAT_ID=123456789

# Valgfrit: antal sider der hentes pr. portal (nyeste ligger på side 1).
POLL_PAGES=1
